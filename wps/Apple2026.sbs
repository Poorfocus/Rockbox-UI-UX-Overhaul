# Apple2026 SBS â€” Interpod DNA + Apple2026 style layer
# 320x240 iPod Classic / Video
# Structural foundation: Interpod Rev.17 by Christian Soffke (CC-BY-SA)
# Apple2026 layer: FFFFFF shell, 16px margins, large title at root, SF Pro fonts
#
# KEY BEHAVIOUR:
#   Stopped  â†’ no bottom bar; full-height content area (main_full viewport)
#   Playing  â†’ 44px mini-player bar (art + title + play/pause indicator)
#   Paused   â†’ 44px mini-player bar (art + title + paused indicator)
#   Root     â†’ Single 38px title band ("Library" + battery); no compact header
#   Non-root â†’ 30px compact header with centered title
#
# Font heights (RB12 actual, not nominal):
#   Slot 2: 28-SFProDisplay-Bold    â†’ h=34px (large title)
#   Slot 3: 16-SFProText-Semibold   â†’ h=20px (header/mini-player)
#   Slot 5: 18-SFProText-Regular    â†’ h=23px (list rows)
#   Slot 6: 16-SFProText-Regular    â†’ h=20px (dense lists)
#
# %mp branch mapping (numeric): 0=stop, 1=play, 2=pause, 3=ff, 4=rew
#

# â”€â”€ Font slots â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Slot 2: large title â€” 28pt SF Pro Display Bold (RB12 height = 34px)
%Fl(2,28-SFProDisplay-Bold.fnt)
# Slot 3: header chrome â€” 16pt SF Pro Text Semibold (RB12 h=20px)
%Fl(3,16-SFProText-Semibold.fnt)
# Slot 5: list rows â€” 18pt SF Pro Text Regular (RB12 h=23px)
%Fl(5,18-SFProText-Regular.fnt)
# Slot 6: dense list rows â€” 16pt SF Pro Text Regular (RB12 h=20px; loaded by list.c)
%Fl(6,16-SFProText-Regular.fnt)
# Slot 7: lockscreen clock â€” 35pt SF Pro Display Bold (RB12 h=43px)
%Fl(7,35-SFProDisplay-Bold.fnt)
# Slot 8: compact secondary labels + mini-player title â€” 14pt SF Pro Text Regular (RB12 h=18px)
%Fl(8,14-SFProText-Regular.fnt)

# â”€â”€ Asset preloads â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# playerStatus: 16x18 per tile, 4 frames â€” Pa=stop Pb=pause-bars Pc=play-fill Pd=ff
%xl(P,playerStatus.bmp,0,0,4)
%xl(A,holdSlider.bmp,0,0,2)
%xl(S,sleep.bmp,0,0)
%xl(L,busyIndicator.bmp,0,0,16)
%xl(B,batteryStatus.bmp,0,4,10)
%xl(M,usbBackdrop.bmp,0,0)
%xl(N,LockNotification.bmp,0,0)
%xl(O,LockNotifPlay.bmp,0,0,2)
%xl(T,playerStatusLarge.bmp,0,0,4)
%xl(Z,miniplayer_bg.bmp,0,0)
%xl(Y,art_mask.bmp,0,0)
%xl(Q,qs_wheel.bmp,0,0)
%xl(V,qs_bar_fill.bmp,0,0)
%xl(W,qs_bar_track.bmp,0,0)
%xl(X,qs_sun_max.bmp,0,0)
%xl(R,qs_sun_min.bmp,0,0)

# â”€â”€ Shell routing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
#
# VI selection:
#   Lockscreen (cs=1 + hold) â†’ lock_empty (1x1, suppresses list rendering)
#   Normal â†’ mp-based routing:
#     branch 0 = STATUS_STOP  â†’ main_full (no bottom bar, full content area)
#     branch 1 = STATUS_PLAY  â†’ mainlarge (content above 44px mini-player)
#     branch 2 = STATUS_PAUSE â†’ mainlarge (content above 44px mini-player, paused)
#     %Lo true = at root â†’ _lt variant (starts at y=38, below large title)
#
%?if(%cs, =, 10)<%VI(qs_blank)|%?mp<%?Lo<%VI(main_full_lt)|%VI(main_full)>|%?Lo<%VI(mainlarge_lt)|%VI(mainlarge)>|%?Lo<%VI(main_full_lt)|%VI(main_full)>|%?Lo<%VI(mainlarge_lt)|%VI(mainlarge)>|%?Lo<%VI(mainlarge_lt)|%VI(mainlarge)>>>
#
# Bottom bar + volume:
#   Stopped (mp=0)      â†’ bottom 50px lane is explicitly cleared back to shell
#   Playing/Paused      â†’ same lane redraws body + title + art + icon every SBS pass
#   Volume adjust       â†’ same lane redraws body + volume overlay instead of title/art
#
# The earlier `%Vl/%Vd` ownership model was unstable under steady-state SBS updates:
# transient/full redraws could reveal the content lanes, then the hidden-viewport
# cleanup path would blank them on the next ordinary action update. Keep the
# mini-player in normal always-rendered SBS viewports instead.
#
# Header indicators
%?Lo<%Vd(battery_icon_root)|%Vd(battery_icon)>
%?if(%St(battery display), =, numeric)<%?Lo<%Vd(batterytext_root)|%Vd(batterytext)>>
%?mh<%Vd(lock)|>
%?bs<%Vd(sleeptimertext)|>
%?lh<%?if(%St(battery display), =, numeric)<%Vd(busyindicatorleft)|%Vd(busyindicator)>|>
#
# Header title â€” suppressed at root (large title replaces it)
%?Lo<|%?if(%St(battery display), =, numeric)<%Vd(title)|%Vd(titlewide)>>
#
# Large title â€” root only
%?Lo<%Vd(large_title)|>
%?if(%cs, =, 10)<|%?mv(1.2)<%?mp<|%Vd(mp_volume_bg)%Vd(mp_volume_clip)||%Vd(mp_volume_bg)%Vd(mp_volume_clip)|%Vd(mp_volume_bg)%Vd(mp_volume_clip)>>|>
#
# USB backdrop
%?if(%cs, =, 21)<%xd(M)>

# Homescreen lockscreen â€” covers root menu when hold is engaged
# %?if(%cs, =, 1)<%?mh<%Vd(home_lock_wallpaper)%Vd(home_lock_clock)%Vd(home_lock_date)%Vd(home_lock_battery)%?bs<%Vd(home_lock_sleep)>%Vd(home_lock_notif)%Vd(home_lock_notif_art)%Vd(home_lock_title)%Vd(home_lock_artist)%Vd(home_lock_play)%?pS(0.2)<%Vd(home_lock_refresh)>|>|>

# â”€â”€ Header background (30px, FFFFFF) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%V(0,0,-,30,-)
%Vf(FFFFFF)
%Vb(FFFFFF)

# â”€â”€ Header title (when battery % shown â€” shorter to leave room for numbers) â”€â”€
# Font slot 3 RB12 height = 20px; VP height must be >= 20 to avoid clipping.
%Vl(title,74,5,-74,20,3)
%Vf(000000)
%Vb(FFFFFF)
%s%ac%?cs<|%Sx(of)|Recording|FM Radio|%Lt|%Lt|%Lt|%Lt|%Lt|%?cf<%cH:%cM|%cl:%cM %cP>|%Lt|%Lt|%Lt|%Lt|%?if(%Lt, =,Context Menu)<Perform Action...|%Lt>|%Lt|%Lt|%Lt|%Lt|%Lt|>

# â”€â”€ Header title (when battery % not shown â€” wide) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(titlewide,56,5,-56,20,3)
%Vf(000000)
%Vb(FFFFFF)
%s%ac%?cs<|%Sx(of)|Recording|FM Radio|%Lt|%Lt|%Lt|%Lt|%Lt|%?cf<%cH:%cM|%cl:%cM %cP> - %?if(%bl, =, 100)<100%%|%bl%%>|%Lt|%Lt|%Lt|%Lt|%?if(%Lt, =,Context Menu)<Perform Action...|%Lt>|%Lt|%Lt|%Lt|%Lt|%Lt|>

# â”€â”€ Large title band (root only â€” replaces compact header, Apple Music style) â”€
# Font slot 2 actual bitmap height = 34px; VP height must be >= 34.
# At root: single 38px band holds "Library" title + battery/status icons.
# No separate compact header at root â€” saves vertical space for content.
%Vl(large_title,16,2,-16,35,2)
%Vf(000000)
%Vb(FFFFFF)
%s%alLibrary

# â”€â”€ Content viewports (full width: selector + list dividers edge-to-edge; 16px row
#    inset is applied in apps/gui/bitmap/list.c for Apple2026 iPod targets)
# mainlarge: used when playing/paused (content area above 50px mini-player)
%Vi(-,0,38,-,-50,5)
%Vf(000000)
%Vb(FFFFFF)

%Vi(mainlarge,0,30,-,-50,5)
%Vf(000000)
%Vb(FFFFFF)

%Vi(mainlarge_lt,0,38,-,-50,5)
%Vf(000000)
%Vb(FFFFFF)

# main_full: used when stopped (no bottom bar â€” full content area)
%Vi(main_full,0,30,-,-,5)
%Vf(000000)
%Vb(FFFFFF)

%Vi(main_full_lt,0,38,-,-,5)
%Vf(000000)
%Vb(FFFFFF)

# quick settings suppresses underlying list ownership entirely; the overlay
# itself is drawn later in the SBS and the native quickscreen body is suppressed
# in core, so this viewport only prevents background list redraw bleed-through.
%Vi(qs_blank,0,0,1,1,5)
%Vf(FFFFFF)
%Vb(FFFFFF)

# 1x1 hidden content VP â€” used for lockscreen (no list content shown)
%Vi(lock_empty,0,0,1,1,5)
%Vf(FFFFFF)
%Vb(FFFFFF)

# â”€â”€ Lock icon â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(lock,-82,6,9,12,-)
%Vb(FFFFFF)
%xd(Ab)

# â”€â”€ Battery percentage text â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Font slot 6 RB12 h=20px; VP height = 20 to prevent clipping.
%Vl(batterytext,-70,5,38,20,6)
%Vf(000000)
%Vb(FFFFFF)
%?if(%bl, =, 100)<100%%|%bl%%>

# â”€â”€ Battery text within large-title band (root only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(batterytext_root,-70,5,38,20,6)
%Vf(000000)
%Vb(FFFFFF)
%?if(%bl, =, 100)<100%%|%bl%%>

# â”€â”€ Sleep timer text countdown â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(sleeptimertext,-100,5,58,20,6)
%Vf(8E8E93)
%Vb(FFFFFF)
%bs

# â”€â”€ Battery icon (upper-right â€” moved up 2px from prior position) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(battery_icon,-32,3,-,20,3)
%Vf(000000)
%Vb(FFFFFF)
%?bp<%?bl<%xd(Ba)|%xd(Ba)|%xd(Ba)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Be)|%xd(Be)>|%?bl<%xd(Bf)|%xd(Bf)|%xd(Bf)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bj)|%xd(Bj)>>

# â”€â”€ Battery icon aligned within large-title band (root only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(battery_icon_root,-32,3,-,20,3)
%Vf(000000)
%Vb(FFFFFF)
%?bp<%?bl<%xd(Ba)|%xd(Ba)|%xd(Ba)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Be)|%xd(Be)>|%?bl<%xd(Bf)|%xd(Bf)|%xd(Bf)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bj)|%xd(Bj)>>

# â”€â”€ Busy indicator â€” right side (no battery %) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
%Vl(busyindicator,-50,8,9,9,-)
%Vb(FFFFFF)
%t(0.1)%xd(La);%t(0.1)%xd(Lb);%t(0.1)%xd(Lc);%t(0.1)%xd(Ld);%t(0.1)%xd(Le);%t(0.1)%xd(Lf);%t(0.1)%xd(Lg);%t(0.1)%xd(Lh);%t(0.1)%xd(Li);%t(0.1)%xd(Lj);%t(0.1)%xd(Lk);%t(0.1)%xd(Ll);%t(0.1)%xd(Lm);%t(0.1)%xd(Ln);%t(0.1)%xd(Lo);%t(0.1)%xd(Lp)

