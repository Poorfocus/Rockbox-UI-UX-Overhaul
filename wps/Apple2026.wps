# Apple2026 WPS  -  Major Polish Pass
# Base: Interpod Rev.17 structural DNA
# 320x240  -  iPod Classic 6G/7G and iPod Video 5G/5.5G
#
# Font heights (RB12 actual, not nominal):
#   Slot 3: 14-SFProText-Regular.fnt     -> h=18px
#   Slot 6: 13-SFCompactText-Regular.fnt -> h=15px
#   Slot 8: 20-SFProText-Medium.fnt      -> h=25px (unused in layout)
#   Slot 9: 16-SFProText-Medium.fnt      -> h=20px
#
# Bottom-zone layout (abs y, 240px screen, art bottom = y=158):
#   gap:          2px
#   Title         y=161  h=20  font 9 (16pt Medium, RB12 h=20)
#   Artist/Album  y=180  h=18  font 3 (14pt Regular, RB12 h=18) alternating
#   gap:          3px
#   pb bar        y=201  h=4   bitmap pill bar (Apple Music style, 4px)
#   gap:          3px
#   time row      y=208  h=18  font 3 (14pt Regular, RB12 h=18)
#   bottom pad:   14px remaining (to screen edge at 240)
#
# Bottom-relative equivalents (240 - abs_y):
#   Title   y=-79  (240-161=79)
#   ArtAlb  y=-60  (240-180=60)
#   pb      y=-39  (240-201=39)
#   time    y=-32  (240-208=32)
#   vbar    y=-40  replaces pb+time while adjusting volume

# Disable status bar
%wd

# Font slots (4 slots only - all verified present in fonts/)
# Slot 3: 14-SFProText-Regular.fnt     (RB12 h=18)
# Slot 6: 13-SFCompactText-Regular.fnt (RB12 h=15, small status labels)
# Slot 8: 20-SFProText-Medium.fnt      (RB12 h=25, kept for compat)
# Slot 9: 16-SFProText-Medium.fnt      (RB12 h=20, title)
%Fl(3,14-SFProText-Regular.fnt)
%Fl(6,13-SFCompactText-Regular.fnt)
%Fl(8,20-SFProText-Medium.fnt)
%Fl(9,16-SFProText-Medium.fnt)
%Fl(7,35-SFProDisplay-Bold.fnt)

# Preload icons  -  Interpod-aligned core IDs plus dedicated Apple2026 shuffle
# playerStatus: 16x18 per tile, 4 frames â€” Pa=stop Pb=pause-bars Pc=play-fill Pd=ff
%xl(N,playerStatusLarge.bmp,0,0,4)
%xl(A,holdSlider.bmp,0,0,2)
%xl(B,batteryStatus.bmp,0,4,10)
%xl(O,repeatLarge.bmp,0,0)
%xl(Q,shuffleLarge.bmp,0,0)
%xl(L,losslessIndicator.bmp,0,0)
%xl(C,speaker_loud.bmp,266,1)

# Preload pill-shaped progress bar bitmaps
%xl(E,pb.bmp,0,0)
%xl(F,pb_backdrop.bmp,0,0)
%xl(G,pb_active.bmp,0,0)
%xl(H,pb_active_backdrop.bmp,0,0)
# Preload pill-shaped volume bar bitmaps
%xl(I,vb.bmp,0,0)
%xl(J,vb_backdrop.bmp,0,0)
# Preload album art framing assets (Apple Music-style rounded corners + soft shadow)
%xl(K,wpsArtCorners.bmp,0,0)



# ---------
# Logic
# ---------

# Display battery percentage when numeric mode enabled
%?mh<|%?if(%St(battery display), =, numeric)<%Vd(batterytext)>>

# Display lock icon when hold slider engaged
%?mh<%Vd(lock)|>

# Display volume bar while adjusting volume; otherwise show time+progress
%?mv(1.2)<%Vd(volumebar)|%Vd(pl_counter)%Vd(elapsed_time)%Vd(lossless_ind)%Vd(remain_time)%?if(%mp,<,4)<%Vd(pb)|%Vd(pb_active)>>

# Always display the hero art. The corner trim now lives inside the same %VB
# viewport and is drawn after %Cd, so it updates in the same pass as the art.
%Vd(album_art)

# Always display the title lane explicitly; relying on the unlabeled auto-draw
# path caused the hero title to flash briefly during full refreshes and then
# disappear on steady-state WPS updates.
%Vd(title_line)

# Always display the single alternating artist/album viewport
%Vd(artist_line)

# Active-only playback-state/status lane on the right
%Vd(shuffle_state)
%Vd(repeat_icon_state)
%Vd(repeat_label_state)
%Vd(player_status_lane)

# Sleep timer
%?bs<%Vd(sleeptimer)>

# Lockscreen engagement is handled natively (WPS becomes the lockview + lock icon)
# Removed custom notification lockscreen overlay per simplification pass

# ---------
# Viewports
# ---------

# Global backdrop layer (stock shell tone, hero shadow baked in at art position)
%V(0,0,-,-,-)%VB
%x(WPSBackdrop,wpsBackdrop.bmp,0,0)

# Album art  -  150x150, centered (x=85), y=8
# %VB pattern (Interpod-proven): art compositor buffer
# Corner trim is drawn in this same viewport after %Cd. The trim corners are
# backdrop-matched cutout pixels, so the curved edge reveals the real shadowed
# shell instead of flat white caps on top of the shadow.
%Vl(album_art,85,8,150,150,-)%VB
%Vf(FFFFFF)
%Vb(FFFFFF)
%Cl(0,0,150,150,c,c)
%?C<|%x(AlbumPlaceholder,albumPlaceholder.bmp,0,0)>
%Cd%xd(K)

# Main display layer  -  chrome on top of backdrop
%V(0,0,-,-,-)

# Player status icon  -  top-left (16x18 tile: Pa=stop Pb=pause-bars Pc=play Pd=ff)
# Branch: 0=stop 1=play(â†’show play-triangle) 2=pause(â†’show pause-bars) 3=ff 4=rew
# Battery icon  -  top-right (moved up 2px)
%V(-32,3,-,20,3)
%Vf(000000)
%Vb(FFFFFF)
%?mh<|%?bp<%?bl<%xd(Ba)|%xd(Ba)|%xd(Ba)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bb)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bc)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Bd)|%xd(Be)|%xd(Be)>|%?bl<%xd(Bf)|%xd(Bf)|%xd(Bf)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bg)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bh)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bi)|%xd(Bj)|%xd(Bj)>>>

# Hold slider locked
%Vl(lock,24,7,9,12,-)
%Vb(FFFFFF)
%xd(Ab)

# Battery percentage text (font slot 3, RB12 h=18; VP h=18)
%Vl(batterytext,-70,5,38,18,3)
%Vf(000000)
%Vb(FFFFFF)
%?if(%bl, =, 100)<100%%|%bl%%>

# Sleep timer text
%Vl(sleeptimer,37,5,53,18,3)
%Vf(000000)
%Vb(FFFFFF)
%bs

# Repeat mode â€” icon + text label for readability
%Vl(shuffle_state,281,103,20,15,-)
%Vb(FFFFFF)
%?or(%if(%ps, =, s),%if(%mm, =, 3))<%xd(Q)>

# Shuffle indicator â€” shown when enabled
%Vl(repeat_icon_state,281,124,20,15,-)
%Vb(FFFFFF)
%?mm<|%xd(O)|%xd(O)|%xd(O)|%xd(O)>

%Vl(repeat_label_state,264,140,54,15,6)
%Vf(8E8E93)
%Vb(FFFFFF)
%ac%?mm<||All|One|All|A-B>

# Playlist position  -  centered in time row (font slot 3, RB12 h=18; VP h=18)
%Vl(pl_counter,107,-32,106,18,3)
%Vf(6E6E73)
%Vb(FFFFFF)
%ac%pp %Sx(of) %pe

# Song title  -  16pt Medium (slot 9, RB12 h=20); width locked to the
# metadata safe area so long titles never enter the bottom-right status lane.
%Vl(title_line,18,-79,258,20,9)
%Vf(000000)
%Vb(FFFFFF)
%s%al%?it<%it|%fn>

# Artist / Album  -  14pt Regular (slot 3, RB12 h=18); VP h=18
# Single viewport alternates: 5s artist (gray), then 5s album (darker gray).
# Width matches the title safe area so the right lane stays reserved for status.
%Vl(artist_line,18,-60,258,18,3)
%Vf(8E8E93)
%Vb(FFFFFF)
%t(5)%s%al%?ia<%ia|%fn>;%t(5)%s%al%?id<%id|%fn>

# Player status icon  -  bottom-right, aligned to the playback/time zone rather
# than the top chrome. Branch: 0=stop 1=play 2=pause 3=ff 4=rew
%Vl(player_status_lane,280,178,20,20,-)
%Vb(FFFFFF)
%?mh<|%?mp<|%xd(Nc)|%xd(Nb)|%xd(Nd)|%xd(Nd)|>>

# -------------------------------------------------------
# Progress bar  -  bitmap pill bars (restored from Interpod pattern)
# 280x8 / 280x9 pill BMPs generated by apple2026_wps_pill_bars.py
# -------------------------------------------------------

# Progress bar (inactive - uses pill bitmap)
%Vl(pb,20,-39,-20,4,-)
%Vf(3C3C43)
%Vb(C7C7CC)
%pb(0,0,-,4,image,E,backdrop,F)

# Progress bar (active - uses pill bitmap, 1px taller for visual weight)
%Vl(pb_active,20,-39,-20,5,-)
%Vf(3C3C43)
%Vb(C7C7CC)
%pb(0,0,-,5,image,G,backdrop,H)

# Elapsed time  -  left, 14pt Regular (RB12 h=18), gray
%Vl(elapsed_time,18,-32,87,18,3)
%Vf(6E6E73)
%Vb(FFFFFF)
%s%al%pc

# Lossless indicator  -  right of center, only shown for lossless formats
%Vl(lossless_ind,127,-12,66,11,-)
%Vb(FFFFFF)
%?or(%if(%fc, =, 4),%if(%fc, =, 5),%if(%fc, =, 7),%if(%fc, =, 11),%if(%fc, =, 13))<%xd(L)>

# Remaining time  -  right, 14pt Regular (RB12 h=18), gray
%Vl(remain_time,-87,-32,-20,18,3)
%Vf(6E6E73)
%Vb(FFFFFF)
%s%ar-%pr

# -------------------------------------------------------
# Volume bar  -  shown while scroll wheel adjusts volume
# Occupies the progress+time zone (y=-40, h=20)
# -------------------------------------------------------
%Vl(volumebar,0,-40,-,20,-)
%Vf(3C3C43)
%Vb(C7C7CC)
%x(M,speaker_mute.bmp,35,1)
%pv(58,8,204,4,image,I,backdrop,J)
%xd(C)
